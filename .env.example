# ── REQUIRED ──────────────────────────────────────────────────
# Resend — for contact form email notifications (resend.com)
RESEND_API_KEY=re_your_key_here

# Supabase — contact form submissions storage
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ── OPTIONAL — Analytics ──────────────────────────────────────
# Vercel Analytics is enabled automatically on Vercel deployment
# Plausible (privacy-first analytics)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=buteforce.com

# ── APP URL ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://buteforce.com
